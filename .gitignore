# Swanlake — .gitignore
#
# Local state and generated artifacts that MUST NOT be committed. The
# canary registry in particular is a LOCAL secret: publishing it defeats
# the entire attribution mechanism (see docs/THREAT-MODEL.md §"Registry
# lives only on the local dev host").

# Generated beacon outputs with filled-in per-surface canary tokens.
defense-beacon/reference/out/
defense-beacon/reference/.canary-state.json
defense-beacon/reference/.canary-state.json.lock

# Any canary registry file that happens to be inside the tree.
canary-strings.txt
**/canary-strings.txt

# Local verifier config — can contain local file paths, op-specific metadata.
defense-beacon/reference/verify.local.yaml
trust-zones/reference/zones.local.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Node / TS (for future @swanlake/node package)
node_modules/
dist/
.turbo/
.next/
*.tsbuildinfo

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Local-only overrides
*.local
*.local.*

# White Cells (Phase 1 alpha experiment) — runtime state.
# Findings, closure-rate rows, and quarantine logs are local artifacts and
# must never be committed; they may contain reproduction strings drawn from
# adversarial inputs.
experiments/white-cells/state/*.jsonl

# Phase 2/3 — auto-triage output + Hook-Fuzzer snapshot of operator's
# settings.json. Both are local artifacts.
experiments/white-cells/findings/*.json
experiments/white-cells/fixtures/settings-snapshot.json

# Phase 2/3 — sandbox-target fixture content written by personas at
# runtime. The directory layout itself is tracked (with .gitkeep
# markers); the contents are throwaway.
#
# Pattern: ignore everything under sandbox_targets/ EXCEPT the .gitkeep
# marker files that pin the four canonical persona subdirs.
experiments/white-cells/fixtures/sandbox_targets/**
!experiments/white-cells/fixtures/sandbox_targets/__init__.py
!experiments/white-cells/fixtures/sandbox_targets/beacon_burner/
!experiments/white-cells/fixtures/sandbox_targets/zone_climber/
!experiments/white-cells/fixtures/sandbox_targets/reflex_smuggler/
!experiments/white-cells/fixtures/sandbox_targets/hook_fuzzer/
!experiments/white-cells/fixtures/sandbox_targets/**/.gitkeep
